{
  "name": "guildrank-hosted",
  "version": "2.0.0",
  "description": "GuildRank — hosted multi-server Discord bot. One invite link, zero setup.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "node --test tests/**/*.test.js",
    "test:smoke": "node --test tests/**/*.test.js",
    "deploy:guild": "node scripts/deployGuildCommands.js",
    "deploy:global": "node scripts/deployGlobalCommands.js",
    "setup-db": "node scripts/setupDb.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
}
